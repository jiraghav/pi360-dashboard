# Copy to keystore.properties (gitignored) next to this file.
# Generate a keystore once, then keep it and the passwords outside git.
#
# keytool -genkey -v -keystore pi360-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias pi360
#
# storeFile is relative to the android/ directory.
#
# Google Play: create the app in Play Console, enable Play App Signing, and upload
# an AAB built with Build > Generate Signed Bundle in Android Studio (or
# ./gradlew bundleRelease with this keystore). Keep the upload key backup safe;
# Play holds the app signing key. Bump versionCode in android/app/build.gradle
# for each Play upload.

storeFile=pi360-release.jks
storePassword=your-store-password
keyPassword=your-key-password
keyAlias=pi360
